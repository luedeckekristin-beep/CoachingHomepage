---
const navItems = [
  { href: '/mein-coaching/', label: 'Mein Coaching' },
  { href: '/ueber-mich/', label: 'Über mich' },
  { href: '/kontakt/', label: 'Kontakt' },
  { href: '/faq/', label: 'FAQ' },
];

const currentPath = Astro.url.pathname;
---

<header class="w-full border-b border-primary/10 bg-bg/80 backdrop-blur-sm sticky top-0 z-50">
  <div class="w-full flex items-center justify-between py-4 px-6 md:px-10">
    <!-- Name ganz links -->
    <a href="/" class="font-sans font-medium text-lg text-primary no-underline hover:text-primary-light">
      Kristin Lüdecke
    </a>

    <!-- Navigation ganz rechts, enger -->
    <nav class="hidden md:flex items-center gap-6">
      <ul class="flex gap-6 list-none m-0 p-0">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class={`text-sm no-underline transition-colors ${
                currentPath === item.href
                  ? 'text-primary font-medium'
                  : 'text-ink hover:text-primary'
              }`}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Sticky CTA-Button -->
      <a
        href="/kontakt/"
        class="inline-flex items-center justify-center px-4 py-2 bg-primary text-ink-light text-sm rounded-md no-underline hover:bg-primary-dark transition-colors"
      >
        Kennenlerngespräch vereinbaren
      </a>
    </nav>

    <!-- Mobile Menu Toggle -->
    <button
      id="mobile-menu-toggle"
      class="md:hidden text-primary p-2"
      aria-label="Menü öffnen"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </div>

  <!-- Mobile Menu -->
  <nav id="mobile-menu" class="hidden md:hidden border-t border-primary/10 bg-bg">
    <ul class="py-4 px-6 list-none m-0 flex flex-col gap-3">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class={`block py-2 no-underline ${
              currentPath === item.href ? 'text-primary font-medium' : 'text-ink'
            }`}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
