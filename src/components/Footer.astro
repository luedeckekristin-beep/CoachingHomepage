---
import { link } from '../utils/link';
const year = new Date().getFullYear();
---

<footer class="border-t border-primary/10 mt-24 py-10 bg-bg-card">
  <div class="container-wide flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
    <div class="text-sm text-ink-soft">
      © {year} Kristin Lüdecke
    </div>

    <nav>
      <ul class="flex flex-wrap gap-6 list-none m-0 p-0 text-sm">
        <li>
          <a href={link('/impressum/')} class="text-ink-soft no-underline hover:text-primary">Impressum</a>
        </li>
        <li>
          <a href={link('/datenschutz/')} class="text-ink-soft no-underline hover:text-primary">Datenschutz</a>
        </li>
        <li>
          <a
            href="https://www.linkedin.com/in/kristinluedecke/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-ink-soft no-underline hover:text-primary"
          >
            LinkedIn
          </a>
        </li>
      </ul>
    </nav>
  </div>
</footer>
