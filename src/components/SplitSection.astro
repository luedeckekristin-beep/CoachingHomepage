---
import { link } from '../utils/link';

interface Props {
  imagePosition?: 'left' | 'right';
  imageSrc?: string;
  imageAlt?: string;
  imagePlaceholder?: string;
  bgColor?: string;
  tall?: boolean;
}

const {
  imagePosition = 'right',
  imageSrc,
  imageAlt = '',
  imagePlaceholder = 'Bild folgt',
  bgColor = 'bg-bg-cream',
  tall = false,
} = Astro.props;

const minHeightClass = tall ? 'min-h-[700px]' : 'min-h-[540px]';

const resolvedSrc = imageSrc && !imageSrc.startsWith('http') ? link(imageSrc) : imageSrc;

// Bilder mit Gesicht oben (Portraits) → object-position: center top
// damit der Kopf beim Zuschneiden nicht abgeschnitten wird.
const isPortraitLike = imageSrc?.match(/(portrait|startseite_übermich|kontakt|übermich|faq)/i);
const objectPosition = isPortraitLike ? 'center top' : 'center center';
---

<div class={`w-full grid md:grid-cols-2 ${minHeightClass} ${bgColor}`}>

  <!-- Text-Seite — Reihenfolge je nach imagePosition -->
  <div class={`flex items-center px-10 py-16 md:px-16 md:py-20 ${imagePosition === 'left' ? 'md:order-2' : 'md:order-1'}`}>
    <div class="max-w-lg w-full">
      <slot />
    </div>
  </div>

  <!-- Bild-Seite — volle Höhe, kein Rand -->
  <div class={`relative min-h-[360px] overflow-hidden ${imagePosition === 'left' ? 'md:order-1' : 'md:order-2'}`}>
    {resolvedSrc ? (
      <img
        src={resolvedSrc}
        alt={imageAlt}
        class="absolute inset-0 w-full h-full object-cover"
        style={`object-position: ${objectPosition}`}
      />
    ) : (
      <div class="absolute inset-0 bg-bg-card flex items-center justify-center">
        <span class="text-ink-soft text-sm italic">{imagePlaceholder}</span>
      </div>
    )}
  </div>

</div>
