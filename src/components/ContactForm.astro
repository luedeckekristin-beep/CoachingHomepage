---
interface Props {
  headline?: string;
  intro?: string;
}

const {
  headline,
  intro,
} = Astro.props;

const WEB3FORMS_ACCESS_KEY = 'ebd2ceeb-0b21-4389-8547-28139b93abfb';
---

<div class="bg-bg-card rounded-lg p-8 md:p-12">
  {headline && <h3 class="mb-3 text-primary">{headline}</h3>}
  {intro && <p class="text-ink-soft mb-8 max-w-prose">{intro}</p>}

  <form id="contact-form" class="space-y-5">
    <!-- Web3Forms Konfiguration (unsichtbar) -->
    <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
    <input type="hidden" name="subject" value="Neue Kontaktanfrage über kristinluedecke.de" />
    <input type="hidden" name="from_name" value="Kontaktformular kristinluedecke.de" />
    <!-- Honeypot gegen Spam (unsichtbar für Menschen, für Bots verlockend) -->
    <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

    <div class="grid md:grid-cols-2 gap-5">
      <div>
        <label for="cf-name" class="block text-sm font-medium mb-2 text-ink">
          Name <span class="text-ink-soft font-normal">(optional)</span>
        </label>
        <input
          type="text"
          id="cf-name"
          name="name"
          class="w-full px-4 py-3 rounded-md border border-primary/20 bg-bg-cream text-ink focus:outline-none focus:border-primary"
        />
      </div>

      <div>
        <label for="cf-phone" class="block text-sm font-medium mb-2 text-ink">
          Handynummer <span class="text-ink-soft font-normal">(optional)</span>
        </label>
        <input
          type="tel"
          id="cf-phone"
          name="phone"
          class="w-full px-4 py-3 rounded-md border border-primary/20 bg-bg-cream text-ink focus:outline-none focus:border-primary"
        />
      </div>
    </div>

    <div>
      <label for="cf-email" class="block text-sm font-medium mb-2 text-ink">
        E-Mail-Adresse <span class="text-primary">*</span>
      </label>
      <input
        type="email"
        id="cf-email"
        name="email"
        required
        class="w-full px-4 py-3 rounded-md border border-primary/20 bg-bg-cream text-ink focus:outline-none focus:border-primary"
      />
    </div>

    <div>
      <label for="cf-message" class="block text-sm font-medium mb-2 text-ink">
        Nachricht <span class="text-primary">*</span>
      </label>
      <textarea
        id="cf-message"
        name="message"
        rows="6"
        required
        class="w-full px-4 py-3 rounded-md border border-primary/20 bg-bg-cream text-ink focus:outline-none focus:border-primary resize-y"
      ></textarea>
    </div>

    <div class="flex flex-col md:flex-row md:items-center gap-4 pt-2">
      <button type="submit" id="cf-submit" class="btn-primary">
        <span data-state="idle">Nachricht senden</span>
        <span data-state="loading" class="hidden">Wird gesendet …</span>
      </button>
      <p class="text-xs text-ink-soft m-0 md:max-w-md">
        Deine Daten werden vertraulich behandelt und ausschließlich zur Bearbeitung deiner Anfrage genutzt.
      </p>
    </div>

    <!-- Feedback-Meldungen nach Submit -->
    <div id="cf-success" class="hidden mt-4 p-4 rounded-md bg-primary/10 border border-primary/20 text-primary">
      Danke für deine Nachricht. Ich melde mich innerhalb von zwei Werktagen bei dir.
    </div>
    <div id="cf-error" class="hidden mt-4 p-4 rounded-md bg-red-100 border border-red-300 text-red-800 text-sm">
      Es gab ein Problem beim Senden. Bitte versuche es noch einmal oder schreib mir direkt eine E-Mail.
    </div>
  </form>

  <!-- Alternativer Kontaktweg -->
  <p class="text-sm text-ink-soft mt-8 pt-6 border-t border-primary/10 m-0">
    Alternativ kannst du mir auch direkt eine E-Mail schreiben an
    {' '}
    <a href="mailto:luedeckekristin@gmail.com" class="text-primary underline underline-offset-2">luedeckekristin@gmail.com</a>.
  </p>
</div>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('cf-submit') as HTMLButtonElement | null;
  const successBox = document.getElementById('cf-success');
  const errorBox = document.getElementById('cf-error');

  function setLoading(loading: boolean) {
    if (!submitBtn) return;
    submitBtn.disabled = loading;
    submitBtn.querySelector<HTMLElement>('[data-state="idle"]')?.classList.toggle('hidden', loading);
    submitBtn.querySelector<HTMLElement>('[data-state="loading"]')?.classList.toggle('hidden', !loading);
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    successBox?.classList.add('hidden');
    errorBox?.classList.add('hidden');
    setLoading(true);

    const formData = new FormData(form);
    const jsonObject: Record<string, unknown> = {};
    formData.forEach((value, key) => { jsonObject[key] = value; });

    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Accept: 'application/json',
        },
        body: JSON.stringify(jsonObject),
      });

      const result = await response.json();
      if (result.success) {
        successBox?.classList.remove('hidden');
        form.reset();
      } else {
        console.error('Web3Forms error:', result);
        errorBox?.classList.remove('hidden');
      }
    } catch (err) {
      console.error('Fetch error:', err);
      errorBox?.classList.remove('hidden');
    } finally {
      setLoading(false);
    }
  });
</script>
