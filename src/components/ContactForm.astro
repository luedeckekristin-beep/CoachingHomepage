---
interface Props {
  headline?: string;
  intro?: string;
}

const {
  headline,
  intro,
} = Astro.props;
---

<div class="bg-bg-card rounded-lg p-8 md:p-12">
  {headline && <h3 class="mb-3 text-primary">{headline}</h3>}
  {intro && <p class="text-ink-soft mb-8 max-w-prose">{intro}</p>}

  <form id="contact-form" class="space-y-5">
    <div class="grid md:grid-cols-2 gap-5">
      <div>
        <label for="cf-name" class="block text-sm font-medium mb-2 text-ink">
          Name <span class="text-ink-soft font-normal">(optional)</span>
        </label>
        <input
          type="text"
          id="cf-name"
          name="name"
          class="w-full px-4 py-3 rounded-md border border-primary/20 bg-bg-cream text-ink focus:outline-none focus:border-primary"
        />
      </div>

      <div>
        <label for="cf-phone" class="block text-sm font-medium mb-2 text-ink">
          Handynummer <span class="text-ink-soft font-normal">(optional)</span>
        </label>
        <input
          type="tel"
          id="cf-phone"
          name="phone"
          class="w-full px-4 py-3 rounded-md border border-primary/20 bg-bg-cream text-ink focus:outline-none focus:border-primary"
        />
      </div>
    </div>

    <div>
      <label for="cf-email" class="block text-sm font-medium mb-2 text-ink">
        E-Mail-Adresse <span class="text-primary">*</span>
      </label>
      <input
        type="email"
        id="cf-email"
        name="email"
        required
        class="w-full px-4 py-3 rounded-md border border-primary/20 bg-bg-cream text-ink focus:outline-none focus:border-primary"
      />
    </div>

    <div>
      <label for="cf-message" class="block text-sm font-medium mb-2 text-ink">
        Nachricht <span class="text-primary">*</span>
      </label>
      <textarea
        id="cf-message"
        name="message"
        rows="6"
        required
        class="w-full px-4 py-3 rounded-md border border-primary/20 bg-bg-cream text-ink focus:outline-none focus:border-primary resize-y"
      ></textarea>
    </div>

    <div class="flex flex-col md:flex-row md:items-center gap-4 pt-2">
      <button type="submit" class="btn-primary">Nachricht senden</button>
      <p class="text-xs text-ink-soft m-0 md:max-w-md">
        Deine Daten werden vertraulich behandelt und ausschließlich zur Bearbeitung deiner Anfrage genutzt.
      </p>
    </div>
  </form>

  <!-- Alternativer Kontaktweg -->
  <p class="text-sm text-ink-soft mt-8 pt-6 border-t border-primary/10 m-0">
    Alternativ kannst du mir auch direkt eine E-Mail schreiben an
    {' '}
    <a href="mailto:luedeckekristin@gmail.com" class="text-primary underline underline-offset-2">luedeckekristin@gmail.com</a>.
  </p>
</div>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    const name = (form.querySelector<HTMLInputElement>('#cf-name')?.value || '').trim();
    const phone = (form.querySelector<HTMLInputElement>('#cf-phone')?.value || '').trim();
    const email = (form.querySelector<HTMLInputElement>('#cf-email')?.value || '').trim();
    const message = (form.querySelector<HTMLTextAreaElement>('#cf-message')?.value || '').trim();

    const subject = 'Kontaktanfrage über die Website';
    const bodyLines = [
      name && `Name: ${name}`,
      phone && `Handynummer: ${phone}`,
      email && `E-Mail: ${email}`,
      '',
      'Nachricht:',
      message,
    ].filter((line) => line !== undefined);

    const body = bodyLines.join('\n');
    const mailto = `mailto:luedeckekristin@gmail.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;

    window.location.href = mailto;
  });
</script>
